// Project — top-level planning entity

model Project {
  id          String        @id @default(cuid())
  ownerId     String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      ProjectStatus @default(DRAFT)
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  owner          User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  activities     Activity[]
  sessions       Session[]
  projectCenters ProjectCenter[]
  notifications  Notification[]

  @@index([ownerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}
